# ==============================================================================
# Overseas CGM Agent Backend — Environment Variables
# ==============================================================================
# 复制此文件为 .env 并填写缺失值:
#   cp .env.example .env
#
# .env 文件包含敏感信息，已在 .gitignore 中排除，请勿提交到版本控制。
# 注意: 此路径的 .env 会被 backend/src/core/config.py 中的 pydantic-settings 自动加载。
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Connection Settings
# ------------------------------------------------------------------------------
# Docker Compose 中的数据库（通过 5433 映射端口连接）：
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/cgm_agent

# 本地独立 PostgreSQL（默认 5432 端口）：
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cgm_agent
DB_SCHEMA=staging

# 启动时是否自动建表和播种数据（本地测试建议 true，生产环境建议 false）
AUTO_CREATE_TABLES=true

# ------------------------------------------------------------------------------
# 2. JWT Authentication Settings
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=dev-secret-change-me-32chars-minimum-length-for-jwt-security
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ------------------------------------------------------------------------------
# 3. Data Accuracy Thresholds
# ------------------------------------------------------------------------------
# 血糖低值（<= 4.2 mmol/L）绝对偏差判定阈值 (mmol/L)
DATA_ACCURACY_ABS_THRESHOLD=0.83

# ------------------------------------------------------------------------------
# 4. Logging Settings
# ------------------------------------------------------------------------------
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=DEBUG

# ------------------------------------------------------------------------------
# 5. Vision LLM (Qwen-VL) Settings
# ------------------------------------------------------------------------------
DASHSCOPE_API_KEY=your-dashscope-api-key-here
VLM_BASE_URL=https://ws-q1u9plrwjmlp9bwu.eu-central-1.maas.aliyuncs.com/compatible-mode/v1
INTENT_MODEL=deepseek-v4-flash
VLM_MODEL=qwen3.5-flash
VLM_ENABLED=true
VLM_MAX_RETRIES=2

# ------------------------------------------------------------------------------
# 6. Batch Detection Performance Settings
# ------------------------------------------------------------------------------
BATCH_MAX_SERIALS=50
BATCH_CONCURRENCY=5
TASK_STALE_MINUTES=30

# ------------------------------------------------------------------------------
# 7. File Storage
# ------------------------------------------------------------------------------
FILE_STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# OSS settings. Keep credentials in .env / deployment secrets only.
OSS_ENDPOINT=oss-eu-central-1.aliyuncs.com
OSS_BUCKET=si-agent-overseas-test
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_KEY_PREFIX=si-overseas
OSS_PUBLIC_BASE_URL=
OSS_USE_SIGNED_URL=true
OSS_SIGNED_URL_EXPIRE_SECONDS=600

# ==============================================================================
# 8. LangSmith Tracing
# ==============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=si-overseas
LANGCHAIN_API_KEY=

# ==============================================================================
# 9. Overseas API Settings (海外设备查询 API)
# ==============================================================================
OVERSEAS_API_ENABLED=true
OVERSEAS_API_LOGIN_URL=https://cgm.sibionics.io/center/admin/user/login
OVERSEAS_API_BASE_URL=https://cgm-ce.sisensing.com
OVERSEAS_API_DEVICE_DETAIL_PATH=/system/expand/oversea/deviceDetail
OVERSEAS_API_USERNAME=
OVERSEAS_API_PASSWORD=
